# Discord
DISCORD_TOKEN=
DISCORD_APP_ID=
GUILD_ID=                 # for guild-only slash commands (recommended)
SHOP_FORUM_CHANNEL_ID=    # the forum channel that holds shop threads
MOD_ROLE_IDS=             # comma-separated role IDs allowed to unclaim any plot (e.g. 123,456)

# GitHub repo to update
GITHUB_TOKEN=             # fine-grained token with contents:write to the repo
GITHUB_OWNER=             # username or org
GITHUB_REPO=              # repo name (the GitHub Pages repo)
SHOPS_JSON_PATH=data/shops.json

# Optional: where to read addresses from (plots file in repo)
PLOTS_JSON_PATH=data/plots.json
